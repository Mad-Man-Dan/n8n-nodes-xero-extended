POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# --- n8n editor / OAuth access ---
# Host port for the n8n editor UI. Change this one value to avoid clashing with
# other local projects; the container always listens on 5678 internally.
N8N_HOST_PORT=5699
# Base URLs n8n uses for the editor, webhooks, and OAuth2 redirect URLs.
# These MUST match how you reach n8n in the browser (i.e. the host port above),
# otherwise the Xero OAuth2 redirect/callback will not line up.
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5699/
N8N_EDITOR_BASE_URL=http://localhost:5699/

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/self-hosted-ai-starter-kit?tab=readme-ov-file#for-mac--apple-silicon-users
# OLLAMA_HOST=host.docker.internal:11434

